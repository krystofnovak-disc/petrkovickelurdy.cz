---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, getLocalizedPath, languages } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const { title, description } = Astro.props;

const pageTitle = title ? `${title} | Stellplatz Petřkovice` : 'Stellplatz Petřkovice u Lurdy';
const pageDescription = description ?? t('hero.subtitle');

const navItems = [
  { href: '#vybaveni', label: t('nav.amenities') },
  { href: '#cenik', label: t('nav.pricing') },
  { href: '#galerie', label: t('nav.gallery') },
  { href: '#obsazenost', label: t('nav.availability') },
  { href: '#rezervace', label: t('nav.reservation') },
  { href: '#vylety', label: t('nav.trips') },
  { href: '#kontakt', label: t('nav.contact') },
];

const otherLang = lang === 'cs' ? 'en' : 'cs';
const otherLangLabel = languages[otherLang];
const otherLangPath = lang === 'cs' ? '/en/' : '/';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'cs' ? 'cs_CZ' : 'en_GB'} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="bg-bg text-text font-sans">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm shadow-sm" id="navbar">
      <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
        <a href={getLocalizedPath('/', lang)} class="text-lg font-bold text-primary">
          Stellplatz Petřkovice
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6">
          {navItems.map(item => (
            <a href={item.href} class="text-sm text-text-light hover:text-primary transition-colors">
              {item.label}
            </a>
          ))}
          <a href={otherLangPath} class="text-sm font-medium text-secondary hover:text-primary transition-colors border border-secondary/30 rounded px-2 py-1">
            {otherLangLabel}
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-text" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
        <div class="px-4 py-3 space-y-2">
          {navItems.map(item => (
            <a href={item.href} class="block py-2 text-text-light hover:text-primary transition-colors mobile-nav-link">
              {item.label}
            </a>
          ))}
          <a href={otherLangPath} class="block py-2 font-medium text-secondary hover:text-primary transition-colors">
            {otherLangLabel}
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-text text-bg py-8">
      <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        <p>&copy; {new Date().getFullYear()} Stellplatz Petřkovice u Lurdy. {t('footer.rights')}</p>
        <a href={getLocalizedPath('/provozni-rad', lang)} class="hover:text-primary-light transition-colors">
          {t('footer.rules')}
        </a>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      document.querySelectorAll('.mobile-nav-link').forEach(link => {
        link.addEventListener('click', () => menu?.classList.add('hidden'));
      });

      // Netlify Identity redirect after login
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user) window.netlifyIdentity.on('login', () => {
            document.location.href = '/admin/';
          });
        });
      }
    </script>
  </body>
</html>
