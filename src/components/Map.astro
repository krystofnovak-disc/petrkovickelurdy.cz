---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import settings from '../content/settings.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="kontakt" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">{t('map.title')}</h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="rounded-xl overflow-hidden shadow-sm aspect-[4/3]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d10254!2d17.9667!3d49.5833!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDnCsDM0JzU5LjkiTiAxN8KwNTgnMDAuMSJF!5e0!3m2!1scs!2scz!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Stellplatz Petřkovice u Lurdy - mapa"
        ></iframe>
      </div>

      <div class="flex flex-col justify-center space-y-6">
        <div>
          <h3 class="font-semibold text-lg mb-1">{t('contact.address')}</h3>
          <p class="text-text-light">
            {settings.site_name}<br />
            {settings.address.line1}<br />
            {settings.address.zip}
          </p>
        </div>

        <div>
          <h3 class="font-semibold text-lg mb-1">GPS</h3>
          <p class="text-text-light font-mono text-sm">{settings.gps}</p>
        </div>

        <div>
          <h3 class="font-semibold text-lg mb-1">{t('contact.phone')}</h3>
          <a href={`tel:${settings.phone.replace(/\s/g, '')}`} class="text-primary hover:text-primary-dark transition-colors">
            {settings.phone}
          </a>
        </div>

        <div>
          <h3 class="font-semibold text-lg mb-1">{t('contact.email')}</h3>
          <a href={`mailto:${settings.email}`} class="text-primary hover:text-primary-dark transition-colors">
            {settings.email}
          </a>
        </div>

        <div>
          <h3 class="font-semibold text-lg mb-1">{t('contact.directions')}</h3>
          <p class="text-text-light text-sm">{settings.directions[lang]}</p>
        </div>
      </div>
    </div>
  </div>
</section>
