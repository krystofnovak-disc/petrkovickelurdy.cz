---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import { getTrips } from '../lib/trips';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const trips = await getTrips(lang);

const categoryIcons: Record<string, string> = {
  'kultura': '🏛️', 'culture': '🏛️',
  'příroda': '🌲', 'nature': '🌲',
  'cyklo': '🚴', 'cycling': '🚴',
  'gastro': '🍷',
  'rodiny': '👨‍👩‍👧‍👦', 'families': '👨‍👩‍👧‍👦',
};
---

<section id="vylety" class="py-20 bg-bg">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">{t('trips.title')}</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {trips.map(trip => (
        <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          {trip.image ? (
            <div class="aspect-[3/2] overflow-hidden">
              <img src={trip.image} alt={trip.title} class="w-full h-full object-cover" />
            </div>
          ) : (
            <div class="aspect-[3/2] bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
              <span class="text-4xl">{categoryIcons[trip.category] ?? '📍'}</span>
            </div>
          )}
          <div class="p-4">
            <h3 class="font-semibold mb-1">{trip.title}</h3>
            <p class="text-text-light text-sm mb-3">{trip.description}</p>
            <div class="flex items-center gap-1 text-xs text-secondary">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {t('trips.distance')}: {trip.distance}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
