---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import settings from '../content/settings.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const isMaintenanceMode = settings.maintenance_mode;
---

{isMaintenanceMode ? (
  <section id="rezervace" class="py-20 bg-bg">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">{t('reservation.title')}</h2>
      <div class="bg-white rounded-xl shadow-sm p-8">
        <div class="text-4xl mb-4">🚧</div>
        <p class="text-lg font-medium text-text mb-2">
          {lang === 'cs' ? 'Stellplatz se připravuje' : 'Stellplatz is being prepared'}
        </p>
        <p class="text-text-light">
          {lang === 'cs'
            ? 'Rezervace budou spuštěny, jakmile bude stellplatz připraven. Sledujte tuto stránku pro aktuální informace.'
            : 'Reservations will open once the stellplatz is ready. Check back here for updates.'}
        </p>
        <div class="mt-6">
          <a href={`mailto:${settings.email}`} class="text-primary hover:text-primary-dark transition-colors font-medium">
            {lang === 'cs' ? 'Máte dotaz? Napište nám' : 'Questions? Email us'} &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <section id="rezervace" class="py-20 bg-bg">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">{t('reservation.title')}</h2>

      <form
        name="reservation"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="bg-white rounded-xl shadow-sm p-6 md:p-8 space-y-5"
        id="reservation-form"
      >
        <input type="hidden" name="form-name" value="reservation" />
        <input type="hidden" name="lang" value={lang} />
        <input type="hidden" name="_gotcha" id="_gotcha" />
        <!-- Honeypot: hidden from humans, bots fill it -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </div>
        <!-- Timestamp for timing-based spam check -->
        <input type="hidden" name="_timestamp" id="_timestamp" />

        <div>
          <label for="name" class="block text-sm font-medium mb-1">{t('reservation.name')}</label>
          <input type="text" id="name" name="name" required
            class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="email" class="block text-sm font-medium mb-1">{t('reservation.email')}</label>
            <input type="email" id="email" name="email" required
              class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium mb-1">{t('reservation.phone')}</label>
            <input type="tel" id="phone" name="phone"
              class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="arrival" class="block text-sm font-medium mb-1">{t('reservation.arrival')}</label>
            <input type="date" id="arrival" name="arrival" required
              class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" />
          </div>
          <div>
            <label for="departure" class="block text-sm font-medium mb-1">{t('reservation.departure')}</label>
            <input type="date" id="departure" name="departure" required
              class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="vehicles" class="block text-sm font-medium mb-1">{t('reservation.vehicles')}</label>
            <select id="vehicles" name="vehicles"
              class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary bg-white">
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
            </select>
          </div>
          <div>
            <label for="vehicle-type" class="block text-sm font-medium mb-1">{t('reservation.type')}</label>
            <select id="vehicle-type" name="vehicle-type"
              class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary bg-white">
              <option value="motorhome">{t('reservation.type.motorhome')}</option>
              <option value="caravan">{t('reservation.type.caravan')}</option>
            </select>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <input type="checkbox" id="electricity" name="electricity" value="yes"
            class="rounded border-bg-dark text-primary focus:ring-primary/30 w-4 h-4" />
          <label for="electricity" class="text-sm">{t('reservation.electricity')}</label>
        </div>

        <div>
          <label for="note" class="block text-sm font-medium mb-1">{t('reservation.note')}</label>
          <textarea id="note" name="note" rows="3"
            class="w-full rounded-lg border border-bg-dark px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary resize-none"></textarea>
        </div>

        <p class="text-xs text-text-light">{t('reservation.disclaimer')}</p>

        <button type="submit" id="submit-btn" disabled
          class="w-full bg-primary text-white font-semibold py-3 rounded-lg hover:bg-primary-dark transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          {t('reservation.submit')}
        </button>
      </form>

      <div id="form-success" class="hidden bg-available/10 border border-available rounded-xl p-6 text-center mt-6">
        <p class="text-text font-medium">{t('reservation.success')}</p>
      </div>
    </div>
  </section>
)}

<script>
  const form = document.getElementById('reservation-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const timestampInput = document.getElementById('_timestamp') as HTMLInputElement;
  const gotchaInput = document.getElementById('_gotcha') as HTMLInputElement;

  if (form && timestampInput) {
    // Record load time to detect bots (submit too fast = bot)
    const loadTime = Date.now();
    timestampInput.value = String(loadTime);

    // Enable submit button after 3 seconds (humans won't fill form that fast)
    setTimeout(() => {
      if (submitBtn) submitBtn.disabled = false;
    }, 3000);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Spam checks
      const elapsed = Date.now() - loadTime;
      if (elapsed < 3000) return; // Too fast = bot
      if (gotchaInput && gotchaInput.value) return; // Hidden field filled = bot

      const data = new FormData(form);

      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        form.style.display = 'none';
        success?.classList.remove('hidden');
      } catch {
        form.submit();
      }
    });
  }
</script>
